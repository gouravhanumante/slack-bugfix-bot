# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Azure DevOps (for fetching bug tickets)
ADO_ORG_URL=https://dev.azure.com/yourorg
ADO_PAT=your-personal-access-token
ADO_PROJECT=your-project-name

# GitHub (for repo + PRs)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=your-repo-name
GITHUB_REPO_URL=https://github.com/owner/repo.git

# Legacy Projects (READ-ONLY reference for the AI agent)
LEGACY_ANDROID_PATH=/path/to/legacy-android-app
LEGACY_IOS_PATH=/path/to/legacy-ios-app

# Bot Config
REPO_BASE_BRANCH=main
MAX_AGENT_ITERATIONS=25
MAX_CONCURRENT_TICKETS=1
